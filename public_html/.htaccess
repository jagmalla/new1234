# Auto Business — public webroot rewrite (Apache / A2 hosting)
# Clean paths map onto the ?r= front-controller routes.

RewriteEngine On

# /canvas                  -> index.php?r=canvas
# /api/workflow/save       -> index.php?r=api/workflow/save
# /webhook/<workflow-id>   -> index.php?r=webhook&wf=<workflow-id>
RewriteRule ^webhook/([A-Za-z0-9-]+)/?$ index.php?r=webhook&wf=$1 [QSA,L]

# Generic: anything not a real file/dir is handled by the front controller.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ index.php?r=$1 [QSA,L]

# Defensive: never serve dotfiles (e.g. a stray .env) from the web.
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# --- Cache-busting -----------------------------------------------------------
# Static assets carry a ?v=<mtime> query (see AutoBusiness\Core\Asset::url), so
# their URL changes whenever the file changes — they can be cached aggressively.
# HTML/PHP pages must always be revalidated so a new ?v is picked up at once.
<IfModule mod_headers.c>
    <FilesMatch "\.(js|css|png|jpe?g|gif|svg|webp|ico|woff2?|ttf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    <FilesMatch "\.(php|html?)$">
        Header set Cache-Control "no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                "access plus 1 year"
    ExpiresByType application/javascript  "access plus 1 year"
    ExpiresByType text/javascript         "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType text/html               "access plus 0 seconds"
</IfModule>
