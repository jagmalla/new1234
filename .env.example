# =============================================================================
# Auto Business — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to ".env" and keep it OUTSIDE public_html (it already lives in
# the project root, one level above the webroot). Never commit the real .env.
# =============================================================================

# Application
APP_ENV=local            # local | production. "local" enables the dev staff login shortcut.
APP_BASE_URL=http://localhost:8000

# Database (MySQL / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=auto_business
DB_USER=auto_business
DB_PASS=

# Credential encryption master key (Module 2 CredentialVault, AES-256-GCM).
# Must be 32 random bytes, base64-encoded. Generate one with:
#   php -r "echo base64_encode(random_bytes(32)), PHP_EOL;"
CREDENTIAL_MASTER_KEY=

# Runner: how many seconds a single cron tick may spend before checkpointing and
# resuming on the next tick. Keep comfortably under max_execution_time (~30s).
RUNNER_TICK_BUDGET_SECONDS=25

# Runner: how many concurrent LLM/HTTP calls a fan-out wave may issue (Global
# Rule: 4-5 on A2 shared hosting). Used later by Module 3's orchestrator.
FANOUT_WAVE_SIZE=4
